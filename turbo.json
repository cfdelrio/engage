{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "11",
  "globalEnv": ["DATABASE_URL", "REDIS_URL", "SHADOW_DATABASE_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate:dev": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "prepare": {
      "cache": false
    }
  }
}
